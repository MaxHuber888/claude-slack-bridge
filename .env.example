# Slack Configuration
# Get these from your Slack App settings at https://api.slack.com/apps
SLACK_APP_TOKEN=xapp-your-app-token-here
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# Channel ID to listen to (right-click channel in Slack → Copy link → extract ID)
SLACK_CHANNEL_ID=your-channel-id-here

# LLM Provider Configuration
# Use Anthropic's default or override for other providers (e.g., MiniMax)
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_API_KEY=sk-ant-your-api-key-here
